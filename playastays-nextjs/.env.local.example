# ============================================================
# PlayaStays — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# WordPress REST API base URL (no trailing slash)
WP_API_URL=https://cms.playastays.com/wp-json/wp/v2

# WordPress Application Password — format: "username:app_password"
# Generate at: WP Admin → Users → Edit → Application Passwords
WP_APP_PASSWORD=editor:xxxx xxxx xxxx xxxx xxxx xxxx

# Secret token for Next.js Draft Mode preview
# Must match PLAYASTAYS_PREVIEW_SECRET in wp-config.php
PREVIEW_SECRET=change_me_long_random_string

# Secret token for ISR revalidation webhook
# Must match PLAYASTAYS_REVALIDATE_SECRET in wp-config.php
REVALIDATION_SECRET=change_me_another_long_random_string

# Public API URL for client-side lead form submission
# Same domain as WP_API_URL but accessible from the browser
NEXT_PUBLIC_WP_API_URL=https://cms.playastays.com/wp-json

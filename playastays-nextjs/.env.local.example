# ============================================================
# PlayaStays — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================
#
# Local dev: npm run dev → http://localhost:3010 (see package.json "dev" script).

# WordPress REST API base URL (no trailing slash)
WP_API_URL=https://cms.playastays.com/wp-json/wp/v2

# WordPress Application Password — format: "username:app_password"
# Generate at: WP Admin → Users → Edit → Application Passwords
WP_APP_PASSWORD=editor:xxxx xxxx xxxx xxxx xxxx xxxx

# Secret token for Next.js Draft Mode preview
# Must match PLAYASTAYS_PREVIEW_SECRET in wp-config.php
PREVIEW_SECRET=change_me_long_random_string

# Secret token for ISR revalidation webhook
# Must match PLAYASTAYS_REVALIDATE_SECRET in wp-config.php
REVALIDATION_SECRET=change_me_another_long_random_string

# Public WordPress REST base (no trailing path after /wp-json)
# Used by the app for CMS fetch; `/api/lead` also uses it server-side for submit-lead backup.
# Omit only if you run HubSpot-only (no WordPress lead backup).
NEXT_PUBLIC_WP_API_URL=https://cms.playastays.com/wp-json

# Optional — Google Maps Embed API key (listing location iframe, Contact, etc.).
# Footer uses address + link only; no iframe. Restrict key by HTTP referrer. Never commit live keys.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# Dev only — serve a fake rental for Maps Embed QA (not for production).
# When set to 1, `/rentals/playa-del-carmen/gonzalo-guerrero/map-embed-test-unit/` loads without WP.
# PLAYASTAYS_DEV_FAKE_RENTAL=1

# Dev / design preview — merge 3 local draft posts into blog hub + article routes (Unsplash hero).
# WordPress posts still win if the same slug exists. Omit or unset in production.
# BLOG_PREVIEW_DRAFTS=1

# ── HubSpot (website leads — primary CRM destination) ──────
# Production: "PlayaStays Website Lead Form"
# Forms API: POST https://api.hsforms.com/submissions/v3/integration/submit/{portalId}/{formGuid}
#
# Set these in production (Vercel/host env). Defaults below match the live form field internal names.
# Optional HUBSPOT_FIELD_* overrides if a staging form uses different internal names.
#
HUBSPOT_PORTAL_ID=245837074
HUBSPOT_FORM_GUID=41190c6c-7b27-440b-aec7-9d6368c29f31
#
# Optional — only if your HubSpot form property internal names differ:
# HUBSPOT_FIELD_EMAIL=email
# HUBSPOT_FIELD_FIRSTNAME=firstname
# HUBSPOT_FIELD_LASTNAME=lastname
# HUBSPOT_FIELD_PHONE=phone
# HUBSPOT_FIELD_CITY=city
# HUBSPOT_FIELD_MESSAGE=message
# HUBSPOT_FIELD_LEAD_SOURCE_DETAIL=lead_source_detail
# HUBSPOT_FIELD_CURRENT_MANAGEMENT_STATUS=current_management_status

# ── Future: Airtable operations base (app does not read these yet) ──
# Used when ops defines sync (server job, Zapier, or code in lead-handoff.ts).
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
# AIRTABLE_LEADS_TABLE_ID=
